TZ=Asia/Shanghai
TG_BOT_TOKEN=123456:replace_me
TG_CHAT_ID=123456789
CHECK_INTERVAL=12h
CHECK_LOCAL=true
CLEANUP=true
SETUP_TEST_MESSAGE=true

# server = Telegram 中心端；agent = 远程 VPS Agent
DOCKUP_MODE=server

# Agent Token；Telegram 添加服务器会自动生成单机 Token
DOCKUP_AGENT_TOKEN=

# 中心端可访问地址；远程 Agent 主动连接中心端时使用
DOCKUP_PUBLIC_URL=http://your-server-ip-or-domain:8748

# 可选：预置远程 Agent，格式：id|url|显示名|token；主动连接模式 url 可留空
# DOCKUP_AGENTS=vps1||VPS-1|one_token,vps2||VPS-2|another_token
DOCKUP_AGENTS=

# 中心端 reverse hub / 旧 Agent HTTP API 监听地址和宿主机端口
AGENT_LISTEN=:8748
AGENT_PORT=8748
DOCKUP_NAME=DockUP

# 中心端持久化服务器/配对信息
DOCKUP_DATA=/data/dockup.json
